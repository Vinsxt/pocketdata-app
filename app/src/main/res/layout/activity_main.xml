<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <View
    android:id="@+id/bg_glow"
    android:layout_width="300dp"
    android:layout_height="300dp"
    android:background="@drawable/ic_launcher_background"
    android:backgroundTint="#F0F4F8"
    android:rotation="45"
    android:alpha="0.6"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:translationX="100dp"
    android:translationY="-100dp"/>

    <ImageView
        android:id="@+id/iv_shield_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@android:drawable/ic_lock_idle_lock"
        app:tint="#0F172A"
        android:layout_marginTop="80dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="PocketData"
        android:fontFamily="sans-serif-medium"
        android:textSize="42sp"
        android:textColor="#0F172A"
        android:letterSpacing="-0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_shield_icon" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Menjaga data kamu terorganisir \ndan terlindungi."
        android:fontFamily="sans-serif"
        android:textSize="18sp"
        android:textColor="#64748B"
        android:lineHeight="28sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogleLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Masuk dengan Google"
        android:textColor="#1E293B"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:paddingVertical="16dp"
        android:paddingHorizontal="24dp"
        android:textAllCaps="false"
        android:stateListAnimator="@null"
        app:backgroundTint="#FFFFFF"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp"
        app:cornerRadius="16dp"
        app:elevation="8dp"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_secure"
            app:tint="#10B981"
            tools:ignore="ContentDescription" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" AES-256 Encrypted Connection"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>