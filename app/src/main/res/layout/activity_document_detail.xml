<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <!-- BACK -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="#0F172A"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- IMAGE + DOWNLOAD -->
    <FrameLayout
        android:id="@+id/imageContainer"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginTop="16dp"
        android:background="#F1F5F9"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>

        <!-- DOWNLOAD BUTTON -->
        <ImageButton
            android:id="@+id/btnDownload"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|top"
            android:layout_margin="12dp"
            android:src="@drawable/ic_download"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Download Image"
            app:tint="#0F172A"/>
    </FrameLayout>

    <!-- TITLE -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/imageContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- DESC -->
    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#475569"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvDesc"
        app:layout_constraintBottom_toTopOf="@id/actionContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ================= KTP ================= -->
            <LinearLayout
                android:id="@+id/layoutKtp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="16dp"
                android:background="#F8FAFC"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail KTP"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="8dp"/>

                <!-- NIK -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvNik"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyNik"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- ALAMAT -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvAlamat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyAlamat"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ================= SIM ================= -->
            <LinearLayout
                android:id="@+id/layoutSim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="16dp"
                android:background="#F8FAFC">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail SIM"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="8dp"/>

                <!-- NOMOR SIM -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvNomorSim"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyNomorSim"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- MASA BERLAKU -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvMasaBerlaku"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyMasaBerlaku"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ================= STNK ================= -->
            <LinearLayout
                android:id="@+id/layoutStnk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="16dp"
                android:background="#F8FAFC"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail STNK"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="8dp"/>

                <!-- PLAT NOMOR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvNomorPolisi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyNomorPolisi"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- MERK / TIPE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvMerkTipe"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyMerkTipe"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- JENIS / MODEL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvJenisModel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyJenisModel"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- TAHUN -->
                <TextView
                    android:id="@+id/tvTahun"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

                <!-- ISI SILINDER -->
                <TextView
                    android:id="@+id/tvIsiSilinder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

                <!-- NOMOR RANGKA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvNomorRangka"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyNomorRangka"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- NOMOR MESIN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvNomorMesin"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyNomorMesin"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- NOMOR BPKB -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvNomorBpkb"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyNomorBpkb"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- MASA BERLAKU -->
                <TextView
                    android:id="@+id/tvMasaBerlakuStnk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#334155"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- ================= NPWP ================= -->
            <LinearLayout
                android:id="@+id/layoutNpwp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="16dp"
                android:background="#F8FAFC"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail NPWP"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="8dp"/>

                <!-- NPWP NUMBER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvNpwpNumber"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyNpwpNumber"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- NIK -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvNpwpNik"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#334155"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/btnCopyNpwpNik"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#64748B"/>
                </LinearLayout>

                <!-- NAMA -->
                <TextView
                    android:id="@+id/tvNpwpNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

                <!-- TANGGAL -->
                <TextView
                    android:id="@+id/tvNpwpTanggal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#334155"
                    android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/actionContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- EDIT -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Edit Dokumen"
            android:textColor="#0F172A"
            android:backgroundTint="#E2E8F0"
            android:layout_marginBottom="12dp"
            app:cornerRadius="12dp"/>

        <!-- DELETE -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Hapus Dokumen"
            android:textColor="#FFFFFF"
            android:backgroundTint="#EF4444"
            app:cornerRadius="12dp"/>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>