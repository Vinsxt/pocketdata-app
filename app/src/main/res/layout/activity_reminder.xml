<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFFFF">

    <!-- IMAGE CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardImage"
        android:layout_width="0dp"
        android:layout_height="220dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardBackgroundColor="#F8FAFC"
        app:strokeWidth="1dp"
        app:strokeColor="#E5E7EB">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:background="#F1F5F9"
                android:src="@android:drawable/ic_menu_camera"
                android:padding="36dp"
                app:tint="#94A3B8" />

            <TextView
                android:id="@+id/tvUploadHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap untuk upload foto dokumen"
                android:textColor="#64748B"
                android:layout_gravity="center"/>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- REMINDER DATE -->
    <TextView
        android:id="@+id/tvReminderDate"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Pilih tanggal pengingat/jatuh tempo"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#F8FAFC"
        android:textColor="#0F172A"
        app:layout_constraintTop_toBottomOf="@id/cardImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- REMINDER LABEL -->
    <TextView
        android:id="@+id/tvReminderLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ingatkan saya sebelum:"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#0F172A"
        app:layout_constraintTop_toBottomOf="@id/tvReminderDate"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- REMINDER OPTIONS -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleReminder"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:singleSelection="false"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/tvReminderLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn30"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30 Hari"
            android:textColor="#0F172A"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn7"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7 Hari"
            android:textColor="#0F172A"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn3"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 Hari"
            android:textColor="#0F172A"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 Hari"
            android:textColor="#0F172A"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- NEXT BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Lanjut"
        android:textColor="#ffffff"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>