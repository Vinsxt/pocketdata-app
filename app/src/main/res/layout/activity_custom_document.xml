<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFFFF"
    tools:context=".CustomDocumentActivity">

    <!-- IMAGE CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardImage"
        android:layout_width="0dp"
        android:layout_height="220dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#E5E7EB"
                android:src="@android:drawable/ic_menu_camera"
                android:padding="56dp"
                app:tint="#94A3B8"
                android:contentDescription="Document image preview"/>

            <TextView
                android:id="@+id/tvUploadHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap untuk upload gambar dokumen"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                android:textColor="#64748B"/>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- INFO TEXT -->
    <TextView
        android:id="@+id/tvInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Dokumen ini untuk menyimpan informasi personal tanpa format. Kamu bisa tambahkan judul dan keterangan di halaman berikutnya."
        android:textSize="14sp"
        android:textColor="#475569"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- NEXT BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Lanjut"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>