<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ================= HEADER ================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah STNK Baru"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pastikan data sesuai dengan kartu fisiknya"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginBottom="24dp"/>

            <!-- ================= IMAGE ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardImage"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/imageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="#EEEEEE"
                        android:src="@android:drawable/ic_menu_camera"
                        android:padding="60dp"
                        app:tint="#BDBDBD"/>

                    <TextView
                        android:id="@+id/tvUploadHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap untuk mengunggah foto STNK"
                        android:textColor="#757575"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="16dp"/>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= TEXT INPUTS ================= -->

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nomor Polisi"
                app:boxStrokeColor="#94A3B8"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2.5dp"
                app:hintTextColor="#64748B"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNomorPolisi"
                    android:textColor="#0F172A"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ================= 2 COLUMN ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Merek &amp; Tipe"
                    app:boxStrokeColor="#94A3B8"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2.5dp"
                    app:hintTextColor="#64748B"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMerkTipe"
                        android:textColor="#0F172A"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Jenis &amp; Model"
                    app:boxStrokeColor="#94A3B8"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2.5dp"
                    app:hintTextColor="#64748B"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etJenisModel"
                        android:textColor="#0F172A"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- ================= YEAR & CC ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Tahun Pembuatan"
                    app:boxStrokeColor="#94A3B8"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2.5dp"
                    app:hintTextColor="#64748B"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTahunPembuatan"
                        android:textColor="#0F172A"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Isi Silinder (cc)"
                    app:boxStrokeColor="#94A3B8"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2.5dp"
                    app:hintTextColor="#64748B"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etIsiSilinder"
                        android:textColor="#0F172A"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- ================= SINGLE ================= -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nomor Rangka (VIN)"
                app:boxStrokeColor="#94A3B8"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2.5dp"
                app:hintTextColor="#64748B"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNomorRangka"
                    android:textColor="#0F172A"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nomor Mesin"
                app:boxStrokeColor="#94A3B8"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2.5dp"
                app:hintTextColor="#64748B"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNomorMesin"
                    android:textColor="#0F172A"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ================= FINAL ROW ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Nomor BPKB"
                    app:boxStrokeColor="#94A3B8"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2.5dp"
                    app:hintTextColor="#64748B"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNomorBpkb"
                        android:textColor="#0F172A"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Masa Berlaku STNK"
                    app:boxStrokeColor="#94A3B8"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2.5dp"
                    app:hintTextColor="#64748B"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMasaBerlaku"
                        android:textColor="#0F172A"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- ================= BUTTON ================= -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Lanjut"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="10dp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#7C3AED"
                app:rippleColor="#5B21B6"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>