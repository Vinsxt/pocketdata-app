<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- ================= TITLE ================= -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Masukkan PIN"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= SUBTITLE ================= -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Untuk keamanan akun Anda"
        android:textSize="14sp"
        android:textColor="#64748B"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= OLD PIN (CHANGE MODE) ================= -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilOldPin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:visibility="gone"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="#CBD5E1"
        app:boxStrokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:hintTextColor="#94A3B8">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOldPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="PIN Lama"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:textSize="18sp"
            android:textColor="#0F172A"
            android:textCursorDrawable="@null"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ================= NEW PIN ================= -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="#CBD5E1"
        app:boxStrokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tilOldPin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:hintTextColor="#94A3B8">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Isi PIN"
            android:inputType="numberPassword"
            android:maxLength="6"
            app:hintTextColor="#94A3B8"
            app:boxStrokeColor="#CBD5E1"
            android:textSize="18sp"
            android:textColor="#0F172A"
            android:textCursorDrawable="@null"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ================= CONFIRM PIN ================= -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilConfirmPin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="#CBD5E1"
        app:boxStrokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tilPin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:hintTextColor="#94A3B8">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConfirmPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Konfirmasi PIN"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:textSize="18sp"
            android:textColor="#0F172A"
            android:textCursorDrawable="@null"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ================= SUBMIT BUTTON ================= -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Lanjut"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:layout_marginTop="32dp"
        app:cornerRadius="14dp"
        app:backgroundTint="#0F172A"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tilConfirmPin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= FORGOT PIN ================= -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnForgotPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lupa PIN?"
        android:textSize="14sp"
        android:textAllCaps="false"
        android:backgroundTint="@android:color/transparent"
        android:textColor="#2563EB"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnSubmit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>