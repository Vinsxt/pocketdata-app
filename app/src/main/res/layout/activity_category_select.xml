<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="#0F172A"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Pilih Tipe Dokumen"
        android:textSize="28sp"
        android:textColor="#0F172A"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="-0.01"
        app:layout_constraintTop_toBottomOf="@id/btn_close"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih jenis dokumen yang mau kamu lindungi."
        android:textSize="16sp"
        android:textColor="#64748B"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:alignmentMode="alignMargins"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ktp"
            android:text="KTP"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:textColor="#0F172A"
            app:backgroundTint="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:icon="@android:drawable/ic_menu_my_calendar"
            app:iconTint="#3B82F6"
            app:iconGravity="textTop"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sim"
            android:text="SIM"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:textColor="#0F172A"
            app:backgroundTint="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:icon="@android:drawable/ic_menu_directions"
            app:iconTint="#10B981"
            app:iconGravity="textTop"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stnk"
            android:text="STNK"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:textColor="#0F172A"
            app:backgroundTint="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:icon="@android:drawable/ic_menu_mapmode"
            app:iconTint="#F59E0B"
            app:iconGravity="textTop"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_npwp"
            android:text="NPWP"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:textColor="#0F172A"
            app:backgroundTint="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:icon="@android:drawable/ic_menu_compass"
            app:iconTint="#8B5CF6"
            app:iconGravity="textTop"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reminder"
            android:text="Pengingat Baru"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:textColor="#0F172A"
            app:backgroundTint="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:icon="@android:drawable/ic_menu_agenda"
            app:iconTint="#EC4899"
            app:iconGravity="textTop"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_custom"
            android:text="Dokumen Baru"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:textColor="#0F172A"
            app:backgroundTint="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="#64748B"
            app:iconGravity="textTop"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>