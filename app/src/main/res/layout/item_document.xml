<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_document"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#F1F5F9"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_image_wrapper"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_doc_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:background="#F8FAFC"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_doc_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Passport Scan.pdf"
            android:textSize="16sp"
            android:textColor="#0F172A"
            android:fontFamily="sans-serif-medium"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintStart_toEndOf="@id/cv_image_wrapper"
            app:layout_constraintTop_toTopOf="@id/cv_image_wrapper"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_doc_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Backup copy for travel visa application."
            android:textSize="13sp"
            android:textColor="#64748B"
            android:fontFamily="sans-serif"
            android:ellipsize="end"
            android:maxLines="2"
            app:layout_constraintStart_toStartOf="@id/tv_doc_name"
            app:layout_constraintTop_toBottomOf="@id/tv_doc_name"
            app:layout_constraintEnd_toEndOf="@id/tv_doc_name" />

        <TextView
            android:id="@+id/tv_doc_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Added: Oct 24, 2025"
            android:textSize="11sp"
            android:textColor="#94A3B8"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="@id/tv_doc_name"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_doc_desc"
            app:layout_constraintVertical_bias="1.0" />

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@android:drawable/ic_lock_lock"
            app:tint="#10B981"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/tv_doc_date"
            app:layout_constraintBottom_toBottomOf="@id/tv_doc_date"
            app:layout_constraintTop_toTopOf="@id/tv_doc_date"
            tools:ignore="ContentDescription" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>